# 이 파일을 .env로 복사하고 값을 채우세요.  cp .env.example .env && chmod 600 .env
# .env는 절대 git에 커밋하지 마세요 (.gitignore 포함).

# [필수: 재무 수집] DART OpenAPI 키 — https://opendart.fss.or.kr (무료, 즉시 발급)
# 이 키가 있으면 value/turnaround가 실제 재무로 동작합니다.
OPENDART_API_KEY=

# [선택: 뉴스 수집] Naver Search API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# [서버 배포 시] Nginx 서브 경로 배포용 prefix
# 루트 배포면 비워 둠. 예: /ttakquant
BASE_PATH=

# [자동매매] 증권사 선택 — 'kis'(한국투자증권), 추후 'nh'(NH투자증권 나무)
BROKER_PROVIDER=kis

# [자동매매] 한국투자증권 KIS OpenAPI
# 발급: https://securities.koreainvestment.com → Open Trading → OpenAPI 신청
# ⚠️ KOREAINVESTMENT_MODE=mock(모의투자)이 안전 기본값. prod(실계좌)는 충분한 검증 후에만.
KOREAINVESTMENT_APP_ID=
KOREAINVESTMENT_SECRET=
KOREAINVESTMENT_ACCOUNT=     # 형식: XXXXXXXX-XX (계좌 8자리-상품 2자리)
KOREAINVESTMENT_MODE=mock
